# SILLION — variáveis de ambiente (copie para .env.local)

# Sessão dos vendedores (CRM)
JWT_SECRET=altere-para-um-segredo-longo-aleatorio

# Painel master (/master/login)
MASTER_USERNAME=MatheusBraga
# Hash bcrypt da senha master — gere com: npm run master:hash -- SUA_SENHA
# IMPORTANTE: use aspas no .env — o $ do bcrypt quebra em shell/systemd sem aspas
MASTER_PASSWORD_HASH=
# Opcional: segredo separado para cookie master
# MASTER_JWT_SECRET=

# Produção sem HTTPS (só IP): necessário para o login funcionar
# COOKIE_SECURE=false
